{
  "manifest_version": 3,
  "name": "MBL And Container Tracker",
  "version": "1.0.3",
  "description": "Track shipments from any webpage. Select a Container or MBL No, right-click, and choose *Track Shipment* to open the tracking page",
  "permissions": [
    "scripting",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "https://ecomm.one-line.com/*",
    "https://www.msc.com/*",
    "https://www.oocl.com/*",
    "https://www.track-trace.com/*",
    "https://ct.shipmentlink.com/*",
    "https://www.cma-cgm.com/*",
    "https://www.maersk.com/*",
    "https://www.hmm21.com/*",
    "https://www.hapag-lloyd.com/*",
    "https://elines.coscoshipping.com/*",
    "https://portal.vanguardlogistics.com/*",
    "https://www.wanhai.com/*",
    "https://www.yangming.com/*",
    "https://www.emiratesline.com/*",
    "https://www.zim.com/*",
    "https://esvc.smlines.com/*",
    "http://elines.hedehk.com/*",
    "https://www.pilship.com/*",
    "https://www.sea-lead.com/*",
    "https://www.sethshipping.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:4200/*",
        "https://trace.divitsoftlabs.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MBL And Container Tracker"
  }
}